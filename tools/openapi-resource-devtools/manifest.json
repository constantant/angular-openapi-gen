{
  "manifest_version": 3,
  "name": "OpenAPI Resource Mocks",
  "version": "0.3.2",
  "description": "Inspect and control @constantant/openapi-resource-mocks tokens in Angular apps",
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "sw.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
